# Database
DATABASE_URL="postgresql://babili:babili_dev_pass@localhost:5432/babili?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# PostgreSQL (for Docker Compose)
POSTGRES_DB=babili
POSTGRES_USER=babili
