{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@babili/shared": ["packages/shared/src"],
      "@babili/database": ["packages/database/src"],
      "@/*": ["apps/web/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "services/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
